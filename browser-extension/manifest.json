{
  "manifest_version": 3,
  "name": "号池监控浏览器助手",
  "description": "读取渠道向导当前填写的 New API 地址，并导入该站点的登录会话。",
  "version": "1.0.0",
  "minimum_chrome_version": "102",
  "permissions": [
    "cookies",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "打开号池监控"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "128": "icon.png"
  }
}
