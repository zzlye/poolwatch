# 首次部署前必须生成，生成后不得随意更换
APP_ENCRYPTION_KEY=

# 首次创建管理员时使用，创建完成后应轮换为新的随机长串
SETUP_TOKEN=

# 对外访问地址必须与浏览器地址一致，正式环境应使用 HTTPS
PUBLIC_BASE_URL=https://monitor.example.com

# 本机映射端口，默认仅允许服务器本机访问
APP_PORT=8080

# 仅在确实需要检测内网渠道时开启
ALLOW_PRIVATE_TARGETS=false

# 默认时区
TZ=Asia/Shanghai

# 仅在使用可选 Caddy 方案时填写
DOMAIN=monitor.example.com
ACME_EMAIL=admin@example.com
